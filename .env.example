# GovOps v2.1 — example environment variables for the hosted demo
#
# Copy to `.env` for local docker-compose runs, or paste each variable into
# the Hugging Face Space's Settings → Secrets dashboard for the live deploy.
# All secrets live OUTSIDE the repo — never commit a populated .env file.
#
# See DEPLOY.md for the end-to-end deploy recipe.

# ---------------------------------------------------------------------------
# Demo mode
# ---------------------------------------------------------------------------
# Activates the demo-mode middleware (header on every response), the
# scheduled GC, and frontend banners. Local dev should leave this UNSET.
GOVOPS_DEMO_MODE=1

# Token gating POST /api/admin/gc. Any random string. Generate with e.g.
# `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
DEMO_ADMIN_TOKEN=replace-with-a-random-string

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------
# SQLite path. On HF Spaces free tier the /data path is ephemeral across
# cold restarts (substrate re-hydrates from lawcode/ on boot per ADR-010);
# on persistent-storage Spaces, /data survives restarts.
GOVOPS_DB_PATH=/data/govops.db

# Seed the demo drafts on every cold boot so the approvals queue is non-empty.
GOVOPS_SEED_DEMO=1

# ---------------------------------------------------------------------------
# LLM provider chain — at least one is required. The proxy tries them in the
# order listed in LLM_PROVIDERS and fails over on 429 / 5xx.
# ---------------------------------------------------------------------------
LLM_PROVIDERS=groq,openrouter,gemini,mistral

# Groq — sign up at https://console.groq.com (free, no credit card)
GROQ_API_KEY=
# Optional overrides — defaults to llama-3.3-70b-versatile @ groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter — sign up at https://openrouter.ai (free models available)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google Gemini — sign up at https://aistudio.google.com (generous free tier)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Mistral La Plateforme — sign up at https://console.mistral.ai (EU-hosted, free tier)
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ---------------------------------------------------------------------------
# Rate limiting (defaults match the v2.1 plan — abuse fence on the free tier)
# ---------------------------------------------------------------------------
# Per-IP per-minute cap on the LLM proxy
RATE_LIMIT_PER_MINUTE=5
# Per-IP per-day cap on the LLM proxy
RATE_LIMIT_PER_DAY=100
# Comma-separated list of route prefixes to rate-limit
RATE_LIMITED_PATHS=/api/llm/chat

# ---------------------------------------------------------------------------
# HF Spaces requires the public process to listen on 0.0.0.0:7860
# ---------------------------------------------------------------------------
PORT=7860
HOST=0.0.0.0
