{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(govops-demo:*)",
      "Bash(python -m uvicorn:*)",
      "Bash(pip install:*)",
      "Bash(.venv/Scripts/python:*)",
      "Bash(source .venv/Scripts/activate)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude-hooks/pre-commit-pytest.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude-hooks/post-edit-pycollect.sh"
          }
        ]
      }
    ]
  }
}
